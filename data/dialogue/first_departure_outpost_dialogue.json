{
	"dialogue_id": "first_departure_outpost_dialogue",
	"skippable": false,
	"entries": [
		{"speaker_id": "operator_404", "speaker_name": "404 哨所调度员", "text": "出发前最后确认一次任务目标。"},
		{"speaker_id": "operator_404", "speaker_name": "404 哨所调度员", "text": "地表的旧通道已经不能稳定往返。你上去以后，升降通道会被暗潮反冲干扰，回来的路会暂时损坏。"},
		{"speaker_id": "player", "speaker_name": "玩家", "text": "也就是说，我不能直接回来？"},
		{"speaker_id": "operator_404", "speaker_name": "404 哨所调度员", "text": "不能。至少不能立刻回来。"},
		{"speaker_id": "operator_404", "speaker_name": "404 哨所调度员", "text": "你需要在地表找到前哨站材料。我们已经把它们标成菱形信号，靠近后会更容易识别。"},
		{"speaker_id": "operator_404", "speaker_name": "404 哨所调度员", "text": "收集足够材料后，修复两处前哨站。前哨站会重新建立地面信号链。"},
		{"speaker_id": "operator_404", "speaker_name": "404 哨所调度员", "text": "两处前哨都修好后，通道才能被重新激活，撤离信号才会亮起。"},
		{"speaker_id": "player", "speaker_name": "玩家", "text": "如果没来得及修好呢？"},
		{"speaker_id": "operator_404", "speaker_name": "404 哨所调度员", "text": "暗潮会不断压缩你的视野，也会让你的稳定值持续下降。"},
		{"speaker_id": "operator_404", "speaker_name": "404 哨所调度员", "text": "稳定值太低时，你会越来越难判断周围情况。不要贪，物资再多也得活着带回来。"},
		{"speaker_id": "operator_404", "speaker_name": "404 哨所调度员", "text": "记住顺序：先找菱形材料，修复前哨站，再撤离。"},
		{"speaker_id": "operator_404", "speaker_name": "404 哨所调度员", "text": "回到基地后，你的稳定值会恢复。那里也是你整理物资、出售战利品和准备下一次探索的地方。"},
		{"speaker_id": "player", "speaker_name": "玩家", "text": "收到。先找材料，修前哨，再回来。"},
		{"speaker_id": "operator_404", "speaker_name": "404 哨所调度员", "text": "祝你好运。404 哨所等你回来。"}
	]
}
